# ─── Groq API keys ──────────────────────────────────────────────────────────
# Primary key (used for the /api/upload-lab-results vision OCR and as
# the fallback for any specialty that doesn't have its own key set).
GROQ_API_KEY=gsk_replace_me

# Per-specialty keys — wired to each LangGraph expert in src/llms/groqllm.py.
# Copy the same value as GROQ_API_KEY into each, or issue one key per
# specialty if you want independent rate-limit accounting.
CARDIOLOGY_EXPERT_GROQ_API_KEY=gsk_replace_me
PULMONARY_EXPERT_GROQ_API_KEY=gsk_replace_me
NEUROLOGY_EXPERT_GROQ_API_KEY=gsk_replace_me
DERMATOLOGY_EXPERT_GROQ_API_KEY=gsk_replace_me
GYNECOLOGY_EXPERT_GROQ_API_KEY=gsk_replace_me
OCULOMETRIC_EXPERT_GROQ_API_KEY=gsk_replace_me
GENERAL_PHYSICIAN_GROQ_API_KEY=gsk_replace_me

# Reserved — graphs exist in langgraph.json but are not wired to the
# FastAPI snapshot yet. Keys can stay unset.
INFECTIOUS_DISEASE_EXPERT_GROQ_API_KEY=
PSYCHIATRIC_EXPERT_GROQ_API_KEY=
ENVIRONMENT_EXPERT_GROQ_API_KEY=
ENT_EXPERT_GROQ_API_KEY=
ORTHOPEDIC_EXPERT_GROQ_API_KEY=
PHARMACOLOGY_EXPERT_GROQ_API_KEY=
ENDOCRINOLOGIST_EXPERT_GROQ_API_KEY=
NEPHROLOGY_EXPERT_GROQ_API_KEY=

# ─── Auth / CORS ────────────────────────────────────────────────────────────
# Enable JWT bearer auth on /api/** (default: disabled so the existing
# frontend keeps working out of the box).
MEDVERSE_AUTH_ENABLED=false
MEDVERSE_JWT_SECRET=change-this-to-a-long-random-string
MEDVERSE_JWT_ALG=HS256
MEDVERSE_JWT_EXPIRY_SECONDS=3600

# Dev login credentials exchanged at POST /api/auth/login for a token.
MEDVERSE_DEV_USERNAME=medverse
MEDVERSE_DEV_PASSWORD=medverse

# Comma-separated CORS origin allowlist.
MEDVERSE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── RAG / vector store ─────────────────────────────────────────────────────
# Embedding model for the Chroma history collections. Defaults to
# FremyCompany/BioLORD-2023 (biomedical-domain encoder) with automatic
# fallback to sentence-transformers/all-MiniLM-L6-v2.
MEDVERSE_EMBEDDING_MODEL=FremyCompany/BioLORD-2023

# ─── Streaming payload ──────────────────────────────────────────────────────
# When true, /stream and SQLite snapshots include the raw 800-sample
# waveform buffers (ECG × 3, PPG × 2, audio). Needed for ECGFounder and
# the respiratory CNN adapters; off by default because it inflates SSE
# payloads roughly 40×.
MEDVERSE_INCLUDE_WAVEFORM=false

# When true, every /stream snapshot includes the latest uploaded retinal /
# skin image paths under `imaging.{retinal,skin}.image_path`. Off by default
# because the paths add a small but constant payload tax even when no images
# have been uploaded. The /api/agent/complex-diagnosis route always splices
# in the latest images regardless of this flag.
MEDVERSE_INCLUDE_IMAGING=false

# ─── Consent gate (Phase 5 governance) ──────────────────────────────────────
# When true, /api/digital-twin/scenario, /api/digital-twin/plan, and
# /api/agent/complex-diagnosis 403 unless the patient has an active consent
# record (POST /api/consent first). Default off so existing demos keep
# working — flip on for production posture.
MEDVERSE_CONSENT_REQUIRED=false

# ─── Ledger backend ─────────────────────────────────────────────────────────
# Where the append-only hash-chained event log lives. Today only the SQL
# backend is implemented (writes ledger_events alongside the regular tables).
# A future BlockchainLedgerBackend will plug in here for the MDTBS dual-
# layer architecture (intra-hospital shard + inter-hospital chain).
MEDVERSE_LEDGER_BACKEND=sql

# ─── ECG sample rate ────────────────────────────────────────────────────────
# The vest emits raw ECG samples on a dedicated BLE characteristic at the
# firmware sample rate (333 Hz). The backend deque is sized as
# ECG_SAMPLE_RATE × 4 seconds, so 250 → 1000-sample window, 333 → 1332-sample.
# Lower this only if you're flashing custom firmware that downsamples.
# MEDVERSE_ECG_SAMPLE_RATE=250

# ─── ML model registry ──────────────────────────────────────────────────────
# Root directory searched by the adapters in src/ml/ and src/biometric/.
MEDVERSE_MODELS_DIR=./models

# ─── Biometric ──────────────────────────────────────────────────────────────
# Cosine-similarity threshold for a positive biometric match (0–1).
MEDVERSE_BIOMETRIC_THRESHOLD=0.75

# ─── TimescaleDB (optional — alembic migration target) ──────────────────────
# Only needed when running `alembic upgrade head`. The FastAPI backend
# still uses aegis_local.db (SQLite) by default.
# MEDVERSE_DB_URL=postgresql+asyncpg://medverse:secret@localhost:5432/medverse

# ─── Federated learning (optional) ──────────────────────────────────────────
# FL_SERVER=127.0.0.1:8080
# FL_PATIENT_ID=default_patient
# FL_ROUNDS=10

# ─── ML pipeline data-loading credentials (under models/<slug>/) ────────────
# Kaggle API token — https://www.kaggle.com/settings/account → "Create New API Token"
# Required for: skin_disease, retinal_disease, retinal_age (and ICBHI lung_sound when
# the direct ZIP mirror is unavailable).
KAGGLE_USERNAME=
KAGGLE_KEY=

# HuggingFace token — https://huggingface.co/settings/tokens (read scope is enough).
# Required for: retinal_age (RETFound MAE weights) and any private HF datasets.
HF_TOKEN=

# Synapse access token — https://www.synapse.org/Profile:Tokens
# Required for: parkinson_screener WearGait-PD (gait signals). Voice features
# from UCI Parkinsons download without auth either way.
SYNAPSE_AUTH_TOKEN=

# Allow the large datasets to download on first `python main.py`:
#   • PTB-XL (25 GB)            — ecg_arrhythmia, cardiac_age
#   • PTB diagnostic ECG (7 GB) — cardiac_age
#   • CTU-UHB CTG (500 MB waveforms) — fetal_health (UCI CTG always loaded; CTU is the gated extra)
#   • ISIC 2024 (~25 GB)        — skin_disease (HAM10000 always loaded; ISIC is gated)
# Default off — gated pipelines raise DatasetUnavailable with a clear message.
MEDVERSE_FETCH_LARGE=false

# Optional override for the WESAD root path (real WESAD requires email registration
# at uni-siegen.de). Without this the stress_ans pipeline uses the synthetic generator
# from the source notebook.
# WESAD_ROOT=/path/to/wesad/extracted
