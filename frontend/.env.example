# Copy to frontend/.env.local for local dev, or set in the Vercel
# project environment variables for production.
#
# Local dev: http://localhost:8000
# Production: https://<your-render-service>.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Set to "true" once MEDVERSE_AUTH_ENABLED=true on the backend.
# Drives the auth gate in frontend/middleware.ts (Phase 8).
NEXT_PUBLIC_AUTH_REQUIRED=false
