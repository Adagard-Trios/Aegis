# Copy to frontend/.env.local for local dev, or set in the Vercel
# project environment variables for production.
#
# ── Data plane (Render free tier) ────────────────────────────────────
# Snapshot ingest, history, patients, FHIR, image upload, /health.
# Local dev: http://localhost:8000
# Production: https://medverse-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── AI plane (Hugging Face Spaces free tier, 16 GB RAM) ──────────────
# Handles /api/agent/* — chat, AI assessments, complex-diagnosis. Sits
# on a separate host because LangGraph + Chroma don't fit in Render
# free's 512 MB. When unset (or empty), agent calls fall back to
# NEXT_PUBLIC_API_URL — useful for local dev where you run the agent
# stack inside the same FastAPI as the data plane.
# Production: https://nivakaran-medverse.hf.space
NEXT_PUBLIC_AI_URL=

# Shared key the AI service requires on every /api/agent/* call —
# matches MEDVERSE_AI_KEY on the HF Space + Render proxy + mobile's
# --dart-define=AI_KEY=. Empty means "no header sent" (matches the
# Space's MEDVERSE_AI_KEY-unset case for local dev).
NEXT_PUBLIC_AI_KEY=

# ── Auth ─────────────────────────────────────────────────────────────
# Set to "true" once MEDVERSE_AUTH_ENABLED=true on the backend.
# Drives the auth gate in frontend/middleware.ts (Phase 8).
NEXT_PUBLIC_AUTH_REQUIRED=false
